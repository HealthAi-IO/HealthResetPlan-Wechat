.container { padding: 24rpx; background: #F7FAF9; min-height: 100vh; }

/* 进度卡 */
.progress-card { background: linear-gradient(135deg, #1565C0, #1E88E5); border-radius: 20rpx; padding: 32rpx; margin-bottom: 24rpx; display: flex; align-items: center; }
.progress-left { flex: 1; }
.progress-label { color: rgba(255,255,255,.8); font-size: 24rpx; margin-bottom: 6rpx; }
.progress-count { color: #fff; font-size: 36rpx; font-weight: 800; margin-bottom: 14rpx; }
.progress-bar-wrap { height: 12rpx; background: rgba(255,255,255,.25); border-radius: 999rpx; overflow: hidden; width: 90%; }
.progress-bar-fill { height: 100%; background: #fff; border-radius: 999rpx; transition: width .3s; }
.progress-pct { color: #fff; font-size: 56rpx; font-weight: 900; margin-left: 24rpx; }

/* Card */
.card { background: #fff; border-radius: 20rpx; padding: 28rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(15,23,42,.05); }
.card-title { font-size: 30rpx; font-weight: 800; margin-bottom: 4rpx; }
.card-sub { font-size: 22rpx; margin-bottom: 20rpx; }
.section-head { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.section-arrow { font-size: 22rpx; font-weight: 700; }
.mode-tip { margin-bottom: 18rpx; padding: 14rpx 16rpx; border-radius: 14rpx; background: #EEF6FF; color: #245B91; font-size: 22rpx; line-height: 1.6; }

/* 打卡按钮 */
.clock-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16rpx; }
.clock-btn { background: #F7FAF9; border-radius: 16rpx; padding: 20rpx 6rpx; display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.clock-btn-icon { font-size: 40rpx; }
.clock-btn-label { font-size: 22rpx; font-weight: 700; color: #374151; }

/* 提醒 chip */
.reminder-chips { display: flex; flex-wrap: wrap; gap: 12rpx; }
.reminder-chip { background: #F3F4F6; border-radius: 999rpx; padding: 10rpx 20rpx; font-size: 24rpx; color: #374151; font-weight: 600; }

/* 记录列表 */
.empty-tip { padding: 20rpx 0; font-size: 24rpx; }
.rec-item { padding: 16rpx 0; border-bottom: 1rpx solid #F3F4F6; display: flex; flex-wrap: wrap; align-items: center; gap: 8rpx; }
.rec-item:last-child { border-bottom: none; }
.rec-label { font-size: 26rpx; font-weight: 700; }
.skip-tag { font-size: 20rpx; color: #FB8C00; background: rgba(255,152,0,.1); border-radius: 6rpx; padding: 2rpx 8rpx; margin-left: 6rpx; }
.rec-note { font-size: 22rpx; flex: 1 0 100%; }
.rec-time { font-size: 20rpx; margin-left: auto; }

/* 提醒规则 */
.reminder-item { display: flex; justify-content: space-between; align-items: center; padding: 14rpx 0; border-bottom: 1rpx solid #F3F4F6; }
.reminder-item:last-child { border-bottom: none; }
.reminder-name { font-size: 26rpx; font-weight: 700; margin-bottom: 4rpx; }
.reminder-note { font-size: 22rpx; }
.reminder-channel { margin-top: 8rpx; display: inline-flex; padding: 4rpx 12rpx; border-radius: 999rpx; background: #E8F3FF; color: #1E88E5; font-size: 20rpx; font-weight: 700; }
.reminder-right { display: flex; align-items: center; gap: 16rpx; }
.reminder-time { font-size: 28rpx; font-weight: 700; color: #1E88E5; }
.reminder-del { color: #9CA3AF; font-size: 28rpx; padding: 8rpx; }

/* 弹窗 */
.mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,.4); z-index: 100; }
.popup { position: fixed; bottom: -100%; left: 0; right: 0; background: #fff; border-radius: 32rpx 32rpx 0 0; padding: 40rpx 32rpx 60rpx; z-index: 101; transition: bottom .3s; }
.popup.popup-show { bottom: 0; }
.popup-title { font-size: 32rpx; font-weight: 800; margin-bottom: 28rpx; }
.popup-label { font-size: 24rpx; color: #6B7280; margin-bottom: 10rpx; }
.popup-input { width: 100%; height: 140rpx; background: #F9FAFB; border-radius: 12rpx; padding: 16rpx; font-size: 26rpx; box-sizing: border-box; }
.popup-input-line { width: 100%; border: none; border-bottom: 2rpx solid #E5E7EB; font-size: 30rpx; padding: 12rpx 0; margin-bottom: 24rpx; }
.radio-item { display: inline-flex; align-items: center; margin-right: 32rpx; font-size: 26rpx; margin-bottom: 20rpx; }
.popup-btns { display: flex; gap: 20rpx; margin-top: 28rpx; }
.popup-cancel  { flex: 1; background: #F3F4F6; color: #374151; border: none; border-radius: 999rpx; font-size: 28rpx; padding: 20rpx 0; }
.popup-confirm { flex: 1; background: #1E88E5; color: #fff; border: none; border-radius: 999rpx; font-size: 28rpx; padding: 20rpx 0; }

.time-pickers { display: flex; align-items: center; gap: 16rpx; margin-bottom: 24rpx; }
.time-pick-btn { background: #F3F4F6; border-radius: 12rpx; padding: 14rpx 28rpx; font-size: 30rpx; font-weight: 600; }
.time-sep { font-size: 36rpx; font-weight: 700; }

.muted { color: #6B7280; font-size: 24rpx; }
