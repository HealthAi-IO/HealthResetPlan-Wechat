.container {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 28rpx 80rpx;
  background: #f7faf9;
}

.hero-card {
  padding: 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #fff1f5 0%, #eef7ff 100%);
  box-shadow: 0 10rpx 26rpx rgba(15, 23, 42, 0.05);
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.hero-title {
  color: #1f2937;
  font-size: 36rpx;
  font-weight: 800;
}

.hero-sub {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.6;
}

.hero-badge {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.hero-badge.idle {
  color: #64748b;
  background: rgba(255, 255, 255, 0.8);
}

.hero-badge.warn {
  color: #b76e00;
  background: #fff4d8;
}

.hero-badge.ok {
  color: #117a48;
  background: #e9f9ef;
}

.muted {
  color: #7b8491;
}

.strong {
  font-weight: 700;
  color: #1f2937;
}

.status-card {
  display: flex;
  align-items: center;
  padding: 26rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.status-card.on {
  background: #e6f7ff;
}

.status-dot {
  width: 44rpx;
  height: 44rpx;
  margin-right: 22rpx;
  border-radius: 50%;
  background: #12d66b;
}

.status-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

.status-sub {
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.guide-card {
  margin-top: 24rpx;
  padding: 24rpx;
  border: 2rpx solid #bde4f6;
  border-radius: 24rpx;
  background: #e9f7ff;
}

.guide-title {
  color: #0b83bd;
  font-size: 30rpx;
  font-weight: 800;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.section-arrow {
  flex-shrink: 0;
  color: #0b83bd;
  font-size: 24rpx;
  font-weight: 700;
}

.guide-summary {
  margin-top: 14rpx;
  color: #425466;
  font-size: 24rpx;
  line-height: 1.65;
}

.guide-line {
  margin-top: 14rpx;
  color: #273548;
  font-size: 25rpx;
  line-height: 1.65;
}

.result-card {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #f8fbff;
  border: 2rpx solid #d7e7f5;
}

.result-card.success {
  background: #edf9f1;
  border-color: #bfe7c9;
}

.result-card.warn {
  background: #fff8e8;
  border-color: #f1dca0;
}

.result-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #1f2937;
}

.result-body {
  margin-top: 10rpx;
  color: #4b5563;
  font-size: 25rpx;
  line-height: 1.65;
}

.card {
  margin-top: 24rpx;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.danger-card {
  border: 2rpx solid #ffd7d7;
  background: #fffafa;
}

.card-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #1f2937;
}

.card-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.55;
}

.step-tip {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: #f4f9ff;
  color: #35506b;
  font-size: 23rpx;
  line-height: 1.65;
}

.overview-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 20rpx;
}

.overview-item {
  padding: 22rpx 20rpx;
  border-radius: 20rpx;
  background: #f8fbff;
  border: 2rpx solid #edf2f7;
}

.overview-label {
  color: #64748b;
  font-size: 22rpx;
}

.overview-value {
  margin-top: 10rpx;
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
}

.body-text {
  margin-top: 28rpx;
  color: #5f6b7a;
  font-size: 28rpx;
  line-height: 1.65;
}

.textarea {
  width: 100%;
  min-height: 230rpx;
  max-height: 420rpx;
  box-sizing: border-box;
  margin-top: 24rpx;
  padding: 24rpx;
  border: 2rpx solid #e5eaf0;
  border-radius: 20rpx;
  background: #ffffff;
  color: #1f2937;
  font-size: 28rpx;
  line-height: 1.6;
}

.empty-box {
  margin-top: 24rpx;
  padding: 34rpx 24rpx;
  border-radius: 20rpx;
  background: #f5f9fb;
  color: #7b8491;
  font-size: 28rpx;
  line-height: 1.5;
  text-align: center;
}

.mnemonic-box {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: #f5f9fb;
}

.mnemonic-word {
  width: calc((100% - 24rpx) / 3);
  box-sizing: border-box;
  padding: 12rpx 10rpx;
  border-radius: 12rpx;
  background: #ffffff;
  color: #273548;
  font-size: 22rpx;
  line-height: 1.3;
}

.check-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 20rpx;
  color: #273548;
  font-size: 25rpx;
}

.single-btn {
  width: 100%;
  margin-top: 26rpx;
}

.btn-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.btn-row button {
  flex: 1;
}

.btn-solid,
.btn-ghost {
  height: 84rpx;
  line-height: 84rpx;
  border: none;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.btn-solid {
  color: #ffffff;
  background: #0b83bd;
}

.btn-ghost {
  color: #0b83bd;
  background: #ffffff;
  border: 2rpx solid #e5eaf0;
}

.btn-danger {
  height: 84rpx;
  line-height: 84rpx;
  border: none;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
  background: #e85d75;
}

.kv-row {
  display: flex;
  justify-content: space-between;
  padding: 17rpx 0;
  border-top: 2rpx solid #f0f3f6;
  color: #374151;
  font-size: 26rpx;
}

.kv-row:first-of-type {
  margin-top: 16rpx;
  border-top: none;
}

.tip {
  margin-top: 16rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #fff7e6;
  color: #6b7280;
  font-size: 23rpx;
  line-height: 1.7;
}

.tip-card {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.tip-title {
  color: #1f2937;
  font-size: 30rpx;
  font-weight: 800;
}

.muted-tip {
  background: #f3f7fb;
  color: #64748b;
}

.member-btn {
  width: 100%;
  height: 84rpx;
  margin-top: 24rpx;
  line-height: 84rpx;
  border: none;
  border-radius: 18rpx;
  background: #e8f2ff;
  color: #0b83bd;
  font-size: 28rpx;
  font-weight: 700;
}
