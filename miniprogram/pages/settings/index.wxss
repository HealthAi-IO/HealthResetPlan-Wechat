.container { padding: 24rpx; background: #F7FAF9; min-height: 100vh; }

.account-card { background: linear-gradient(135deg, #1565C0, #1E88E5); border-radius: 20rpx; padding: 32rpx; margin-bottom: 24rpx; display: flex; align-items: center; gap: 20rpx; }
.avatar-wrap { position: relative; width: 88rpx; height: 88rpx; flex-shrink: 0; }
.avatar, .avatar-img { width: 88rpx; height: 88rpx; border-radius: 50%; background: rgba(255,255,255,.25); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 36rpx; font-weight: 700; overflow: hidden; }
.avatar-camera { position: absolute; right: -4rpx; bottom: -4rpx; width: 30rpx; height: 30rpx; border-radius: 50%; background: #fff; display: flex; align-items: center; justify-content: center; font-size: 16rpx; }
.account-info { flex: 1; }
.account-name { color: #fff; font-size: 30rpx; font-weight: 700; margin-bottom: 4rpx; }
.account-id { font-size: 22rpx; color: rgba(255,255,255,.7); }
.account-tag { background: rgba(255,255,255,.2); color: #fff; border-radius: 999rpx; padding: 6rpx 16rpx; font-size: 22rpx; }

.login-card { background: #fff; border-radius: 20rpx; padding: 28rpx; margin-bottom: 24rpx; display: flex; align-items: center; gap: 20rpx; box-shadow: 0 2rpx 12rpx rgba(15,23,42,.05); }
.login-avatar { font-size: 56rpx; flex-shrink: 0; }
.login-info { flex: 1; }
.login-title { font-size: 30rpx; font-weight: 700; margin-bottom: 4rpx; }
.login-sub { font-size: 22rpx; }
.arrow { font-size: 36rpx; }

.section-card { background: #fff; border-radius: 20rpx; padding: 0 20rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 12rpx rgba(15,23,42,.05); }
.cell { display: flex; align-items: center; padding: 28rpx 8rpx; gap: 16rpx; }
.cell-icon { font-size: 36rpx; width: 48rpx; text-align: center; flex-shrink: 0; }
.cell-label { flex: 1; font-size: 28rpx; font-weight: 500; }
.cell-danger { color: #E53935; }
.cell-arrow { font-size: 32rpx; }
.cell-divider { height: 1rpx; background: #F3F4F6; margin: 0 8rpx; }

.sync-tip { padding: 20rpx 8rpx; }
.sync-tip-title { font-size: 26rpx; font-weight: 700; margin-bottom: 10rpx; }
.sync-tip-body { font-size: 22rpx; line-height: 1.6; }

.btn-logout { background: #FEE2E2; color: #E53935; border: none; border-radius: 999rpx; font-size: 28rpx; font-weight: 600; padding: 20rpx 0; margin-bottom: 24rpx; width: 100%; }
.version { text-align: center; padding: 20rpx 0 40rpx; font-size: 22rpx; }

.muted { color: #6B7280; font-size: 24rpx; }
