.container {
  padding: 24rpx 28rpx 80rpx;
  background: #F7FAF9;
  min-height: 100vh;
  box-sizing: border-box;
}

.muted { color: #9CA3AF; }

/* 分段 Tab */
.seg {
  display: flex; background: #fff; border-radius: 16rpx;
  padding: 6rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}
.seg-item {
  flex: 1; text-align: center; padding: 16rpx 0;
  font-size: 28rpx; color: #6B7280; border-radius: 12rpx;
}
.seg-item.active {
  background: linear-gradient(135deg, #1E88E5, #00ACC1);
  color: #fff; font-weight: 700;
}

.section-label {
  font-size: 24rpx; font-weight: 700; color: #6B7280;
  padding: 32rpx 8rpx 14rpx;
}

/* 类型选择 */
.type-grid {
  display: flex; flex-wrap: wrap; gap: 14rpx;
}
.type-chip {
  display: flex; align-items: center; gap: 6rpx;
  padding: 14rpx 20rpx; border-radius: 999rpx;
  background: #fff; border: 2rpx solid #E5E7EB;
  font-size: 26rpx; color: #374151;
}
.type-chip.active {
  background: #1E88E5; border-color: #1E88E5;
  color: #fff; font-weight: 700;
}
.type-icon { font-size: 28rpx; }

/* 卡片 */
.card {
  background: #fff; border-radius: 20rpx;
  padding: 24rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}
.time-row { font-size: 30rpx; color: #1F2937; font-weight: 600; }

.form .field {
  display: flex; align-items: center; padding: 22rpx 0;
  border-bottom: 2rpx solid #F3F4F6;
}
.form .field:last-of-type { border-bottom: none; }
.field-label { width: 180rpx; font-size: 28rpx; color: #374151; font-weight: 600; }
.field-input {
  flex: 1; font-size: 30rpx; color: #1F2937;
  padding: 8rpx 0;
}
.field-unit { font-size: 26rpx; color: #9CA3AF; min-width: 90rpx; text-align: right; }

.sub-label { font-size: 24rpx; color: #6B7280; padding: 18rpx 0 10rpx; }
.chip-row { display: flex; gap: 14rpx; flex-wrap: wrap; }
.sm-chip {
  padding: 10rpx 22rpx; border-radius: 999rpx;
  background: #F3F4F6; color: #6B7280; font-size: 26rpx;
}
.sm-chip.on { background: #1E88E5; color: #fff; font-weight: 700; }

.hint { font-size: 22rpx; padding-top: 12rpx; }

.btn-save {
  margin-top: 36rpx; height: 92rpx; line-height: 92rpx;
  background: linear-gradient(135deg, #1E88E5 0%, #00ACC1 100%);
  color: #fff; font-size: 32rpx; font-weight: 700;
  border-radius: 999rpx; border: none;
  box-shadow: 0 12rpx 28rpx rgba(30,136,229,0.25);
}

/* 历史视图 */
.empty { text-align: center; padding: 120rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }

.group-card {
  background: #fff; border-radius: 20rpx;
  padding: 22rpx 24rpx; margin-top: 18rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}
.group-row { display: flex; align-items: center; }
.g-icon { width: 80rpx; font-size: 38rpx; }
.g-body { flex: 1; }
.g-label { font-size: 30rpx; font-weight: 700; color: #1F2937; }
.g-latest { font-size: 24rpx; margin-top: 6rpx; }
.g-arrow { font-size: 24rpx; padding-left: 12rpx; }

.history-list {
  margin-top: 16rpx; padding-top: 16rpx;
  border-top: 2rpx dashed #E5E7EB;
}
.history-row {
  display: flex; align-items: center;
  padding: 14rpx 0;
}
.history-val { flex: 1; font-size: 28rpx; color: #1F2937; font-weight: 600; }
.history-time { font-size: 22rpx; padding-right: 16rpx; }
.history-del {
  font-size: 22rpx; color: #E53935;
  padding: 6rpx 14rpx; background: #FEE2E2; border-radius: 999rpx;
}
