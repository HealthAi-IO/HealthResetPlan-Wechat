<scroll-view scroll-y class="container">

  <!-- Hero -->
  <view class="hero">
    <view class="hero-title">7 天健康规划</view>
    <view class="hero-sub muted">基于健康档案生成个性化饮食 · 运动 · 测量方案</view>
    <view class="hero-btns">
      <button class="btn-local" bindtap="onGenerate">✨ 本地生成</button>
      <button class="btn-ai {{aiGenerating ? 'disabled' : ''}}" bindtap="onAiGenerate" disabled="{{aiGenerating}}">
        {{aiGenerating ? 'AI 生成中…' : '🤖 AI 智能生成'}}
      </button>
    </view>
  </view>

  <!-- 筛选 -->
  <view class="filters">
    <view class="chip {{filter==='all'       ? 'active' : ''}}" data-filter="all"         bindtap="onFilterTap">全部</view>
    <view class="chip {{filter==='meal'      ? 'active' : ''}}" data-filter="meal"        bindtap="onFilterTap">饮食</view>
    <view class="chip {{filter==='exercise'  ? 'active' : ''}}" data-filter="exercise"    bindtap="onFilterTap">运动</view>
    <view class="chip {{filter==='measurement'?'active' : ''}}" data-filter="measurement" bindtap="onFilterTap">测量</view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{isEmpty}}">
    <view class="empty-icon">📅</view>
    <view class="muted">暂无计划，点击上方按钮生成 7 天方案</view>
  </view>

  <!-- 每日计划 -->
  <view class="day-card" wx:for="{{plans}}" wx:key="date">
    <view class="day-header" data-date="{{item.date}}" bindtap="onToggleDay">
      <view class="day-label">{{item.dateLabel}}</view>
      <view class="day-header-right">
        <view class="day-count muted">{{item.items.length}} 条</view>
        <view class="day-toggle muted">{{item.expanded ? '收起' : '展开'}}</view>
      </view>
    </view>

    <block wx:if="{{item.expanded}}">
      <block wx:for="{{item.items}}" wx:for-item="plan" wx:key="id">
      <!-- 饮食 -->
        <view class="plan-item meal-item" wx:if="{{plan.type === 'meal'}}">
        <view class="plan-header-row">
          <text class="plan-tag meal-tag">🍽 饮食计划</text>
        </view>
        <view class="plan-summary">{{plan.summary}}</view>
        <view class="meals-detail" wx:if="{{plan.mealRows && plan.mealRows.length}}">
          <view class="meal-row" wx:for="{{plan.mealRows}}" wx:for-item="meal" wx:key="slot">
            <text class="meal-slot">{{meal.slot}}</text>
            <text>{{meal.text}}</text>
          </view>
        </view>
      </view>

      <!-- 运动 -->
      <view class="plan-item ex-item" wx:if="{{plan.type === 'exercise'}}">
        <view class="plan-header-row">
          <text class="plan-tag ex-tag">🏃 运动计划</text>
          <text class="plan-intensity muted">{{plan.payload.intensity}}</text>
        </view>
        <view class="plan-summary">{{plan.summary}}</view>
        <view class="plan-desc muted" wx:if="{{plan.payload.desc}}">{{plan.payload.desc}}</view>
      </view>

      <!-- 测量 -->
      <view class="plan-item mea-item" wx:if="{{plan.type === 'measurement'}}">
        <view class="plan-header-row">
          <text class="plan-tag mea-tag">📊 每日测量</text>
        </view>
        <view class="plan-summary">{{plan.summary}}</view>
        <view wx:for="{{plan.measureItems}}" wx:for-item="it" wx:key="*this" class="mea-item-row muted">· {{it}}</view>
      </view>
      </block>
    </block>
    <view class="day-preview muted" wx:else>点击展开查看当天饮食、运动和测量安排</view>
  </view>

  <view style="height:40rpx"></view>

  <view class="ai-mask" wx:if="{{aiPreviewVisible}}" bindtap="onCloseAiPreview"></view>
  <view class="ai-panel" wx:if="{{aiPreviewVisible}}">
    <view class="ai-handle"></view>
    <view class="ai-head">
      <view>
        <view class="ai-title">AI 健康方案</view>
        <view class="ai-provider muted">{{pendingAiPlan.provider}}</view>
      </view>
      <view class="ai-close" bindtap="onCloseAiPreview">关闭</view>
    </view>

    <scroll-view scroll-y class="ai-scroll">
      <view class="ai-summary">{{pendingAiPlan.summary}}</view>
      <view class="ai-meta-row" wx:if="{{pendingAiPlan.keyFocus || pendingAiPlan.targetCalories}}">
        <view class="ai-pill" wx:if="{{pendingAiPlan.keyFocus}}">重点：{{pendingAiPlan.keyFocus}}</view>
        <view class="ai-pill" wx:if="{{pendingAiPlan.targetCalories}}">目标：{{pendingAiPlan.targetCalories}} kcal/天</view>
      </view>
      <view class="ai-risk" wx:if="{{pendingAiPlan.riskAlert}}">{{pendingAiPlan.riskAlert}}</view>

      <view class="ai-invalid" wx:if="{{!pendingAiPlan.executable}}">
        <view class="ai-invalid-title">暂时无法直接应用</view>
        <view class="ai-invalid-text">{{pendingAiPlan.invalidMessage}}</view>
      </view>

      <view class="ai-raw" wx:if="{{pendingAiPlan.rawPreview}}">
        <view class="ai-block-title measurement">原始返回</view>
        <view class="ai-raw-text">{{pendingAiPlan.rawPreview}}</view>
      </view>

      <view class="ai-day" wx:for="{{pendingAiPlan.previewDays}}" wx:key="id">
        <view class="ai-day-title">{{item.dayLabel}}</view>
        <view class="ai-block" wx:if="{{item.mealRows.length}}">
          <view class="ai-block-title meal">饮食</view>
          <view class="ai-meal-row" wx:for="{{item.mealRows}}" wx:for-item="meal" wx:key="slot">
            <text class="ai-meal-slot">{{meal.slot}}</text>
            <text>{{meal.text}}</text>
          </view>
        </view>
        <view class="ai-block" wx:if="{{item.exerciseSummary}}">
          <view class="ai-block-title exercise">运动</view>
          <view class="ai-text">{{item.exerciseSummary}}</view>
        </view>
        <view class="ai-block" wx:if="{{item.reminders.length}}">
          <view class="ai-block-title measurement">提醒</view>
          <view class="ai-text" wx:for="{{item.reminders}}" wx:for-item="reminder" wx:key="*this">· {{reminder}}</view>
        </view>
      </view>
    </scroll-view>

    <view class="ai-actions">
      <button class="ai-secondary" bindtap="onRegenerateAiPlan">重新生成</button>
      <button class="ai-primary {{!pendingAiPlan.executable ? 'disabled' : ''}}" bindtap="onApplyAiPlan" disabled="{{!pendingAiPlan.executable}}">
        {{pendingAiPlan.executable ? '应用方案' : '无法应用'}}
      </button>
    </view>
  </view>
</scroll-view>
