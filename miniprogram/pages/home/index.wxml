<scroll-view scroll-y class="container" bindscrolltolower="onRefresh">

  <!-- Hero 仪表盘 -->
  <view class="hero">
    <view class="hero-top">
      <view class="hero-left">
        <view class="hero-name">你好，{{nickname}}</view>
        <view class="hero-date muted-white">{{todayLabel}}</view>
        <view class="hero-tip muted-white" wx:if="{{!hasProfile}}">请先完善健康档案，开始个性化计划</view>
        <view class="hero-tip muted-white" wx:else>继续保持，稳定打卡是最好的健康投资</view>
      </view>
      <view class="ring" bindtap="onGoClock">
        <view class="ring-pct">{{completionPct}}%</view>
        <view class="ring-label">完成</view>
      </view>
    </view>
    <view class="clock-dots">
      <view class="dot {{doneTypes.meal     ? 'done' : ''}}" bindtap="onGoClock"><view class="dot-icon">🍚</view><view class="dot-text">饮食</view></view>
      <view class="dot {{doneTypes.exercise ? 'done' : ''}}" bindtap="onGoClock"><view class="dot-icon">🏃</view><view class="dot-text">运动</view></view>
      <view class="dot {{doneTypes.medicine ? 'done' : ''}}" bindtap="onGoClock"><view class="dot-icon">💊</view><view class="dot-text">用药</view></view>
      <view class="dot {{doneTypes.weight   ? 'done' : ''}}" bindtap="onGoClock"><view class="dot-icon">⚖️</view><view class="dot-text">称重</view></view>
      <view class="dot go-btn" bindtap="onGoClock"><view class="dot-icon">›</view><view class="dot-text">打卡</view></view>
    </view>
  </view>

  <!-- 新用户数据引导 -->
  <view class="card setup-card" wx:if="{{needsSetup}}">
    <view class="setup-title">{{needsIndicators ? '还缺少健康指标' : '先填写你的健康档案'}}</view>
    <view class="setup-desc muted" wx:if="{{needsIndicators}}">档案已同步/已保存，还需要至少一条血压、体重、血糖或报告识别指标，才能用于分析和生成计划。</view>
    <view class="setup-desc muted" wx:else>当前还没有完整档案。完善年龄、身高、体重和目标后，免费版和会员版会沿用同一份数据。</view>
    <view class="setup-actions">
      <button class="setup-primary" wx:if="{{needsIndicators}}" bindtap="onGoIndicators">录入指标</button>
      <button class="setup-primary" wx:else bindtap="onGoProfile">完善档案</button>
      <button class="setup-outline" wx:if="{{needsIndicators}}" bindtap="onGoReport">报告识别</button>
      <button class="setup-outline" wx:else bindtap="onGoIndicators">录入指标</button>
    </view>
  </view>

  <!-- 今日关键指标 -->
  <view class="card">
    <view class="card-header">
      <view class="section-title-wrap">
        <view class="title-md">今日数据</view>
        <view class="section-sub muted">关键指标一眼看清</view>
      </view>
      <view class="link" bindtap="onGoIndicators">+ 录入</view>
    </view>
    <view class="metrics-grid">
      <view class="metric-tile teal">
        <view class="metric-icon">📊</view>
        <view class="metric-val">{{bmi}}</view>
        <view class="metric-sub">BMI · {{bmiLevel}}</view>
      </view>
      <view class="metric-tile red">
        <view class="metric-icon">❤️</view>
        <view class="metric-val">{{latestBp}}</view>
        <view class="metric-sub">血压 mmHg</view>
      </view>
      <view class="metric-tile blue">
        <view class="metric-icon">⚖️</view>
        <view class="metric-val">{{latestWeight}}</view>
        <view class="metric-sub">体重</view>
      </view>
      <view class="metric-tile orange">
        <view class="metric-icon">💧</view>
        <view class="metric-val">{{latestGlucose}}</view>
        <view class="metric-sub">血糖</view>
      </view>
    </view>
  </view>

  <!-- 今日计划摘要 -->
  <view class="card">
    <view class="card-header">
      <view class="section-title-wrap">
        <view class="title-md">今日计划</view>
        <view class="section-sub muted">饮食、运动与测量安排</view>
      </view>
      <view class="link" bindtap="onGoPlan">全部计划</view>
    </view>
    <block wx:if="{{hasPlan}}">
      <view class="plan-row orange-bg" wx:if="{{todayMealPlan}}">
        <view class="plan-icon">🍽</view>
        <view class="plan-body">
          <view class="plan-type">今日饮食</view>
          <view class="plan-summary muted {{!mealSummaryExpanded && hasLongMealSummary ? 'summary-collapsed' : ''}}">{{todayMealPlan.summary}}</view>
          <view class="summary-toggle" wx:if="{{hasLongMealSummary}}" data-type="meal" bindtap="onTogglePlanSummary">
            {{mealSummaryExpanded ? '收起' : '展开'}}
          </view>
        </view>
      </view>
      <view class="plan-row green-bg" wx:if="{{todayExercisePlan}}">
        <view class="plan-icon">🏋️</view>
        <view class="plan-body">
          <view class="plan-type">今日运动</view>
          <view class="plan-summary muted {{!exerciseSummaryExpanded && hasLongExerciseSummary ? 'summary-collapsed' : ''}}">{{todayExercisePlan.summary}}</view>
          <view class="summary-toggle" wx:if="{{hasLongExerciseSummary}}" data-type="exercise" bindtap="onTogglePlanSummary">
            {{exerciseSummaryExpanded ? '收起' : '展开'}}
          </view>
        </view>
      </view>
    </block>
    <block wx:else>
      <view class="muted" style="margin-bottom:12rpx">暂无今日计划，点击下方生成 7 天方案</view>
      <button class="btn-outline" bindtap="onGeneratePlan">✨ 生成 7 天计划</button>
    </block>
  </view>

  <!-- 快捷入口 -->
  <view class="card">
    <view class="section-title-wrap" style="margin-bottom:16rpx">
      <view class="title-md">快捷入口</view>
      <view class="section-sub muted">常用功能都在这里</view>
    </view>
    <view class="quick-grid">
      <view class="quick-item" bindtap="onGoProfile">
        <view class="quick-icon teal-bg">🗂</view>
        <view class="quick-label">健康档案</view>
      </view>
      <view class="quick-item" bindtap="onGoIndicators">
        <view class="quick-icon blue-bg">📝</view>
        <view class="quick-label">录入指标</view>
      </view>
      <view class="quick-item" bindtap="onGoIndicators">
        <view class="quick-icon indigo-bg">📋</view>
        <view class="quick-label">指标历史</view>
      </view>
      <view class="quick-item" bindtap="onGoPlan">
        <view class="quick-icon green-bg">📅</view>
        <view class="quick-label">7天计划</view>
      </view>
      <view class="quick-item" data-page="stats" bindtap="onGoPage">
        <view class="quick-icon orange-bg">📈</view>
        <view class="quick-label">趋势统计</view>
      </view>
      <view class="quick-item" bindtap="onGoChat">
        <view class="quick-icon indigo-bg">🤖</view>
        <view class="quick-label">AI 助理</view>
      </view>
      <view class="quick-item" bindtap="onGoReport">
        <view class="quick-icon red-bg">📷</view>
        <view class="quick-label">报告 OCR</view>
      </view>
      <view class="quick-item" bindtap="onGoSettings">
        <view class="quick-icon gray-bg">👤</view>
        <view class="quick-label">我的</view>
      </view>
    </view>
  </view>

  <!-- 最近指标 -->
  <view class="card" wx:if="{{recentIndicators.length > 0}}">
    <view class="card-header">
      <view class="section-title-wrap">
        <view class="title-md">最近指标</view>
        <view class="section-sub muted">最近录入的健康变化</view>
      </view>
      <view class="link" bindtap="onGoIndicators">全部</view>
    </view>
    <view class="ind-row" wx:for="{{recentIndicators}}" wx:key="id">
      <view class="ind-badge">{{item.typeLabel}}</view>
      <view class="ind-val">{{item.displayValue}}</view>
      <view class="ind-time muted">{{item.timeLabel}}</view>
    </view>
  </view>

  <!-- 今日打卡 -->
  <view class="card" wx:if="{{todayClocks.length > 0}}">
    <view class="card-header">
      <view class="section-title-wrap">
        <view class="title-md">今日打卡</view>
        <view class="section-sub muted">今天已经完成的动作</view>
      </view>
      <view class="link" bindtap="onGoClock">去打卡</view>
    </view>
    <view class="clock-row" wx:for="{{todayClocks}}" wx:key="id">
      <view class="clock-label">{{item.label}}</view>
      <view class="clock-note muted" wx:if="{{item.note}}">{{item.note}}</view>
      <view class="clock-time muted">{{item.clockTime}}</view>
    </view>
  </view>

  <view class="card sync-card" bindtap="onGoSettings">
    <view class="sync-top">
      <view class="title-md sync-title">云同步与换机恢复</view>
      <view class="sync-badge">{{syncStatusText}}</view>
    </view>
    <view class="muted">
      {{hasCloudSync ? '登录同一账号后，可用助记词恢复手机端数据' : '开通会员后可与手机端同步同一份加密健康数据'}}
    </view>
  </view>

  <view style="height:40rpx"></view>
</scroll-view>
