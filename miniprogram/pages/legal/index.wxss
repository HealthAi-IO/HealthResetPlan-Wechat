.page { min-height: 100vh; padding: 40rpx 32rpx; box-sizing: border-box; background: #f7faf9; color: #1f2937; }
.title { font-size: 44rpx; font-weight: 700; line-height: 1.35; }
.lead { margin: 24rpx 0 32rpx; color: #4b5563; font-size: 30rpx; line-height: 1.7; }
.section { margin-bottom: 24rpx; padding: 28rpx; border-radius: 20rpx; background: #fff; }
.section-title { margin-bottom: 12rpx; font-size: 32rpx; font-weight: 600; }
.section-body { color: #4b5563; font-size: 28rpx; line-height: 1.8; }
.updated { padding: 16rpx 0 40rpx; color: #9ca3af; font-size: 24rpx; text-align: center; }
