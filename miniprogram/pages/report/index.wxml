<view class="container">
  <view class="hero">
    <view class="hero-title">检查报告 OCR</view>
    <view class="hero-sub muted">上传体检、血压、血脂或血糖报告图片，AI 会提取指标并保存到最近报告。</view>
  </view>

  <view class="upload-card">
    <view class="upload-box" bindtap="onChooseImage" wx:if="{{!image}}">
      <view class="upload-icon">+</view>
      <view class="upload-text">选择报告图片</view>
      <view class="upload-hint muted">支持 JPG / PNG / WebP / GIF，单张不超过 5MB</view>
    </view>

    <view class="preview-wrap" wx:else>
      <image class="preview" src="{{image}}" mode="widthFix" bindtap="onPreviewImage" />
      <view class="preview-actions">
        <button class="ghost" bindtap="onChooseImage">重新选择</button>
        <button class="solid {{loading ? 'disabled' : ''}}" bindtap="onUpload" disabled="{{loading}}">
          {{loading ? '识别中...' : '开始识别'}}
        </button>
      </view>
    </view>
  </view>

  <view class="summary-card" wx:if="{{reportSummary}}">
    <view class="summary-head">
      <view class="summary-title">识别摘要</view>
      <view class="summary-toggle" wx:if="{{reportSummary.length > 40}}" bindtap="onToggleSummary">
        {{summaryExpanded ? '收起' : '展开'}}
      </view>
    </view>
    <view class="summary-text {{!summaryExpanded && reportSummary.length > 40 ? 'summary-text-collapsed' : ''}}">{{reportSummary}}</view>
    <view class="summary-meta muted">
      <text wx:if="{{reportDate}}">{{reportDate}}</text>
      <text wx:if="{{reportDate && reportProvider}}"> · </text>
      <text wx:if="{{reportProvider}}">{{reportProvider}}</text>
    </view>
  </view>

  <view class="advice-card" wx:if="{{reportAdvice}}">
    <view class="advice-title">AI 分析建议</view>
    <view class="advice-text">{{reportAdvice}}</view>
  </view>

  <view class="result-card" wx:if="{{result.length}}">
    <view class="result-title">识别到 {{result.length}} 项可导入指标</view>
    <view class="result-row" wx:for="{{result}}" wx:key="key">
      <view class="r-main">
        <view class="r-label">{{item.label}}</view>
        <view class="r-source muted" wx:if="{{item.sourceName}}">来源：{{item.sourceName}}</view>
        <view class="r-source muted" wx:if="{{item.referenceRange}}">参考：{{item.referenceRange}}</view>
      </view>
      <view class="r-val">{{item.value}} <text class="muted">{{item.unit}}</text></view>
      <switch color="#1E88E5" checked="{{item.selected}}" data-idx="{{index}}" bindchange="onToggleSelect" />
    </view>
    <button class="btn-save" bindtap="onImport">导入选中指标</button>
  </view>

  <view class="history-card" wx:if="{{history.length}}">
    <view class="hist-head">
      <view class="hist-title">最近报告</view>
      <view class="hist-total muted">共 {{history.length}} 份</view>
    </view>
    <view class="hist-row" wx:for="{{history}}" wx:key="clientId" data-id="{{item.clientId}}" bindtap="onOpenHistory">
      <image class="hist-thumb" src="{{item.imagePath}}" mode="aspectFill" />
      <view class="hist-body">
        <view class="hist-name">{{item.title}}</view>
        <view class="hist-time muted">{{item.timeLabel}}</view>
        <view class="hist-provider muted" wx:if="{{item.provider}}">{{item.provider}}</view>
      </view>
      <view class="hist-side">
        <view class="hist-count">{{item.indicatorCount}} 项</view>
        <button class="hist-delete" size="mini" data-id="{{item.clientId}}" bindtap="onDeleteHistory">删除</button>
      </view>
    </view>
  </view>

  <view class="tip muted">
    OCR 识别结果用于辅助录入，请在导入前核对数值和单位。最近报告支持删除，也可以点开查看原图、指标和识别原文。
  </view>

  <view class="detail-mask" wx:if="{{detailVisible}}" bindtap="onCloseDetail"></view>
  <view class="detail-panel" wx:if="{{detailVisible}}">
    <view class="detail-handle"></view>
    <view class="detail-head">
      <view>
        <view class="detail-title">报告详情</view>
        <view class="detail-meta muted">{{activeReport.timeLabel}}{{activeReport.provider ? ' · ' + activeReport.provider : ''}}</view>
      </view>
      <view class="detail-close" bindtap="onCloseDetail">关闭</view>
    </view>

    <scroll-view scroll-y class="detail-scroll">
      <view class="detail-section" wx:if="{{activeReport.imagePath}}">
        <view class="detail-section-title">报告原图</view>
        <image class="detail-image" src="{{activeReport.imagePath}}" mode="widthFix" bindtap="onPreviewHistoryImage" />
      </view>

      <view class="detail-section" wx:if="{{activeReport.title}}">
        <view class="detail-section-title">摘要</view>
        <view class="detail-summary">{{activeReport.title}}</view>
      </view>

      <view class="detail-section" wx:if="{{activeReport.analysisAdvice}}">
        <view class="detail-section-title">AI 分析建议</view>
        <view class="detail-advice">{{activeReport.analysisAdvice}}</view>
      </view>

      <view class="detail-section">
        <view class="detail-section-title">识别指标</view>
        <view class="detail-summary" wx:if="{{!activeReport.indicators.length}}">
          {{activeReport.rawText || '这份报告暂未识别出具体指标，请人工核对报告原图。'}}
        </view>
        <view class="detail-indicator" wx:for="{{activeReport.indicators}}" wx:key="id">
          <view class="detail-indicator-top">
            <view class="detail-indicator-name">{{item.name}}</view>
            <view class="detail-indicator-value">{{item.value}} {{item.unit}}</view>
          </view>
          <view class="detail-indicator-bottom">
            <view class="detail-indicator-range muted" wx:if="{{item.referenceRange}}">参考范围：{{item.referenceRange}}</view>
            <view class="detail-status {{item.statusClass}}">{{item.statusLabel}}</view>
          </view>
        </view>
      </view>

      <view class="detail-section" wx:if="{{activeReport.rawText}}">
        <view class="detail-section-head">
          <view class="detail-section-title">识别原文</view>
          <view class="summary-toggle" bindtap="onToggleDetailRaw">{{detailRawExpanded ? '收起' : '展开'}}</view>
        </view>
        <view class="detail-raw {{!detailRawExpanded ? 'detail-raw-collapsed' : ''}}">{{activeReport.rawText}}</view>
      </view>
    </scroll-view>
  </view>
</view>
