page {
  background: #F7FAF9;
  color: #1F2937;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.05);
}

.btn-primary {
  background: linear-gradient(135deg, #2BBE7A, #1E88E5);
  color: #fff;
  border-radius: 999rpx;
  padding: 20rpx 32rpx;
  font-size: 28rpx;
}

.muted { color: #6B7280; font-size: 24rpx; }
.title-lg { font-size: 36rpx; font-weight: 600; }
.title-md { font-size: 30rpx; font-weight: 600; }
